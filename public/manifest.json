{
    "manifest_version": 3,
    "name": "Agente IA Extensão",
    "version": "1.0",
    "description": "Controlador de abas com React e IA",
    "icons": {
        "16": "icon16.png",
        "32": "icon32.png",
        "48": "icon48.png",
        "128": "icon128.png"
    },
    "permissions": [
        "activeTab",
        "scripting",
        "storage",
        "tabs",
        "downloads",
        "cookies",
        "bookmarks",
        "history",
        "clipboardRead",
        "clipboardWrite",
        "offscreen",
        "declarativeNetRequest"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "background": {
        "service_worker": "assets/background.js",
        "type": "module"
    },
    "action": {
        "default_popup": "index.html",
        "default_icon": {
            "16": "icon16.png",
            "32": "icon32.png",
            "48": "icon48.png",
            "128": "icon128.png"
        }
    }
}
